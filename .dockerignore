# Git
.git
.gitignore

# Secrets
.env
*.pem
*.key
# Claude Code auth session must NOT be baked into the image.
# The session is mounted at runtime via the claude-config Docker volume.
.claude/settings.local.json

# Runtime data
jobs/pending/*.json
jobs/running/*.json
jobs/done/*.json
jobs/failed/*.json
logs/

# Development
examples/
templates/
tests/
*.md
!CLAUDE.md

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
