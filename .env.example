# =============================================================================
# .env - Environment Variables for 24/7 Autonomous Coding Agent
# Copy this file to .env and fill in your values
# =============================================================================

# --------------------------------------------------------------------------
# Authentication Mode: Claude Max Plan ($200/mo)
# --------------------------------------------------------------------------
# API key is NOT needed for Max plan.
# Instead, run 'claude login' inside the container once.
# The auth session is persisted via the claude-config volume.
#
# If you want to use API billing instead, uncomment:
# ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# GitHub Personal Access Token (required)
# Needs: repo, read:org, workflow scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SSH key path for git operations (default: ~/.ssh/id_ed25519)
SSH_KEY_PATH=/home/agent/.ssh/id_ed25519

# --------------------------------------------------------------------------
# Usage Control (Max plan quota management)
# --------------------------------------------------------------------------
# Max concurrent Claude invocations (default: 1)
MAX_CONCURRENT=1

# Cooldown between jobs in seconds (saves quota)
JOB_COOLDOWN=60

# Max jobs per day (0 = unlimited). Prevents burning through quota.
MAX_JOBS_PER_DAY=20

# Preferred model: sonnet uses ~5x less quota than opus
# Options: claude-sonnet-4-5-20250929, claude-opus-4-6
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# --------------------------------------------------------------------------
# Optional: Web Dashboard (http://localhost:7860)
# --------------------------------------------------------------------------
# Set a token to enable authentication. Leave empty for no auth (dev only).
# DASHBOARD_TOKEN=your-secret-token-here

# --------------------------------------------------------------------------
# Optional: Notifications
# --------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456789:ABCDEFghijklmnopqrstuvwxyz
# TELEGRAM_CHAT_ID=123456789
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
