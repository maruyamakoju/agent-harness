# Environment secrets
.env

# Auto-queue config (may contain sensitive task details)
config/auto-queue-config.json
# Track example files but ignore real configs
!config/*.example.json

# Job data (runtime state)
jobs/pending/*.json
jobs/running/*.json
jobs/done/*.json
jobs/failed/*.json

# Logs
logs/*.jsonl
logs/*.log
logs/*.json

# Workspaces
workspaces/

# Docker
.docker/

# Python
**/__pycache__/
*.pyc
*.pyo

# Runtime logs (text)
logs/*.txt

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
